# BrainGain environment template
# Copy to your runtime environment and set real values.

# Core runtime
PORT=8000
BRAINGAIN_HOST=0.0.0.0

# Database (set to managed Postgres URL in production)
DATABASE_URL=postgresql://username:password@host:5432/database

# Optional CORS allowlist for split frontend deploys
# Comma-separated origins, e.g. https://app.example.com,https://admin.example.com
BRAINGAIN_CORS_ORIGINS=

# Prototype toggles
# Keep this enabled only for prototype/demo mode.
BRAINGAIN_ENABLE_DEMO_LOGIN=1

# Exposes /project-files/... for uploaded image previews.
# Disable in hardened production unless this route is required.
BRAINGAIN_ENABLE_PROJECT_FILE_PROXY=1
